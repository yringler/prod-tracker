# Copy to .dev.vars for `wrangler dev`. Production: use `wrangler secret put`.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# VAPID keys are base64url raw: public = 65-byte uncompressed point, private = 32-byte d.
# Generate with: npx web-push generate-vapid-keys  (then base64url, no padding)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Zulip adapter secrets (the two ZULIP_ *vars* — SITE, BOT_EMAIL — live in
# wrangler.toml [vars], not here). Get the API key from Zulip: Settings → Bots →
# your Generic bot. ZULIP_WEBHOOK_TOKEN is the shared secret you set on the
# Outgoing-webhook bot and verify on the inbound route.
ZULIP_API_KEY=
ZULIP_WEBHOOK_TOKEN=
# Email adapter secret (the EMAIL_FROM *var* lives in wrangler.toml [vars]).
# Transport API key for a Resend/MailChannels-style HTTP send API.
EMAIL_API_KEY=
APP_ORIGIN = "http://localhost:8787"
