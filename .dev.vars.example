# Copy to .dev.vars for `wrangler dev`. Production: use `wrangler secret put`.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# VAPID keys are base64url raw: public = 65-byte uncompressed point, private = 32-byte d.
# Generate with: npx web-push generate-vapid-keys  (then base64url, no padding)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
APP_ORIGIN = "http://localhost:8787"

# --- Stripe (test mode) ------------------------------------------------------
# Prefer a RESTRICTED key (rk_test_...) with least privilege: write Checkout
# Sessions + Billing Portal Sessions, read Subscriptions + Customers.
STRIPE_SECRET_KEY=sk_test_or_rk_test_...
# The test-mode recurring Price id for the $5/mo plan (a price_..., not a product).
STRIPE_PRICE_ID=price_...
# From `stripe listen` (below). It prints a whsec_... to paste here.
STRIPE_WEBHOOK_SECRET=whsec_...
# Forward webhooks to the local worker while developing:
#   stripe listen --forward-to http://localhost:8787/api/billing/webhook \
#     --events checkout.session.completed,customer.subscription.updated,customer.subscription.deleted
