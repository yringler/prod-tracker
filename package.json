{
  "name": "storypoint-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal/peer story-point effort tracker on top of Jira Cloud",
  "scripts": {
    "typecheck": "tsc -p tsconfig.worker.json --noEmit && tsc -p shared/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "dev": "wrangler dev",
    "deploy": "npm run build:client && wrangler deploy",
    "build:client": "ng build --configuration production --project client"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "better-sqlite3": "^12.11.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.60.0"
  },
  "dependencies": {
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/router": "^18.2.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.14.0"
  },
  "optionalDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0"
  }
}
